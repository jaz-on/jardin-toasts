{
	"name": "jardin-toasts/jardin-toasts",
	"description": "Jardin · Untappd : check-ins bière (CPT), synchro et blocs.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Jardin Toasts Contributors",
			"email": "contributors@example.com"
		}
	],
	"require": {
		"php": ">=8.1",
		"symfony/dom-crawler": "^6.4",
		"symfony/css-selector": "^6.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"wp-coding-standards/wpcs": "^3.0",
		"squizlabs/php_codesniffer": "^3.7",
		"phpstan/phpstan": "^2",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"php-stubs/wordpress-stubs": "^6.9",
		"php-stubs/wordpress-globals": "^0.2.0",
		"php-stubs/wp-cli-stubs": "^2.12"
	},
	"autoload": {
		"classmap": [
			"includes/",
			"admin/",
			"public/"
		],
		"files": [
			"includes/functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"JT\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"phpcs": "phpcs --standard=WordPress --extensions=php --ignore=vendor,node_modules .",
		"phpcbf": "phpcbf --standard=WordPress --extensions=php --ignore=vendor,node_modules .",
		"phpstan": "phpstan analyse --memory-limit=1G -c phpstan.neon.dist",
		"test": "phpunit",
		"hooks:install": "bash scripts/install-git-hooks.sh",
		"release:dev": [
			"@composer install --no-dev --optimize-autoloader",
			"@composer dump-autoload --no-dev --optimize"
		]
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
