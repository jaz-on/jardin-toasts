{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beer-journal/menu-display",
	"title": "Check-ins by venue",
	"category": "widgets",
	"icon": "location",
	"description": "Lists check-ins tagged with a venue term (placeholder until menu taxonomy ships).",
	"textdomain": "beer-journal",
	"attributes": {
		"venueSlug": {
			"type": "string",
			"default": ""
		},
		"postsToShow": {
			"type": "number",
			"default": 12
		}
	},
	"supports": {
		"html": false
	},
	"render": "file:./render.php"
}
